# PreCall environment variables.
# Copy to .env.local and fill in values. Do not commit real secrets.

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------

# Primary Redis connection for the worker queue and idempotency cache.
# Used by: apps/worker, apps/graph, apps/vapi-webhook.
REDIS_URL=

# Test-only Redis (docker-compose.test.yml exposes on 6380).
# Used by: test harness (test/env.ts, test/globalSetup.ts).
REDIS_TEST_URL=

# Test-only Postgres (docker-compose.test.yml exposes on 5433).
# Used by: test harness, infra/seed.
POSTGRES_TEST_URL=

# Primary Postgres / InsForge database URL.
# Used by: apps/graph, apps/worker.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Service ports and tokens
# -----------------------------------------------------------------------------

# HTTP port the service listens on. Per-app default.
# Used by: apps/graph, apps/vapi-webhook, apps/worker.
PORT=

# WunderGraph Cosmo router URL the SDK and apps target for GraphQL.
# Used by: apps/graph, apps/worker.
COSMO_ROUTER_URL=

# Service-to-service bearer token for the Precall graph.
# Used by: apps/worker, apps/vapi-webhook.
PRECALL_SERVICE_TOKEN=

# -----------------------------------------------------------------------------
# Web (Next.js public vars are inlined at build time)
# -----------------------------------------------------------------------------

# Public GraphQL endpoint the browser SDK hits.
# Used by: apps/web.
NEXT_PUBLIC_GRAPH_ENDPOINT=

# Vapi public key used by the browser for voice sessions.
# Used by: apps/web.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Vapi assistant identifier bound to the PreCall voice flow.
# Used by: apps/web.
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# -----------------------------------------------------------------------------
# Vapi webhook
# -----------------------------------------------------------------------------

# HMAC-SHA256 secret for verifying Vapi webhook signatures.
# Used by: apps/vapi-webhook.
VAPI_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# External research and LLM providers
# -----------------------------------------------------------------------------

# TinyFish API key for web extraction of public sources.
# Used by: apps/worker (packages/integrations tinyfish client).
TINYFISH_API_KEY=

# OpenAI API key for LLM calls.
# Used by: apps/worker, apps/graph.
OPENAI_API_KEY=

# Anthropic API key for LLM calls.
# Used by: apps/worker, apps/graph.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (calendar and contacts)
# -----------------------------------------------------------------------------

# Google OAuth client id.
# Used by: apps/graph, apps/web.
GOOGLE_CLIENT_ID=

# Google OAuth client secret.
# Used by: apps/graph.
GOOGLE_CLIENT_SECRET=

# Google OAuth redirect URL registered with the app.
# Used by: apps/graph.
GOOGLE_REDIRECT_URL=

# -----------------------------------------------------------------------------
# Notion OAuth
# -----------------------------------------------------------------------------

# Notion OAuth client id.
# Used by: apps/graph, apps/web.
NOTION_CLIENT_ID=

# Notion OAuth client secret.
# Used by: apps/graph.
NOTION_CLIENT_SECRET=

# Notion OAuth redirect URL registered with the integration.
# Used by: apps/graph.
NOTION_REDIRECT_URL=
