# PreCall environment variables.
# Copy to .env.local and fill in values. Do not commit real secrets.

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------

# InsForge API base URL.
# Used by: apps/web, apps/graph, apps/worker, apps/vapi-webhook, InsForge edge functions.
INSFORGE_URL=https://z5bpjses.us-west.insforge.app

# Optional local InsForge bootstrap credentials.
# Used by: local/dev InsForge setup.
INSFORGE_JWT_SECRET=change-me-32-characters-minimum-xyz
INSFORGE_ADMIN_EMAIL=demo@precall.app
INSFORGE_ADMIN_PASSWORD=change-me

# Primary Redis connection for the worker queue and idempotency cache.
# Used by: apps/worker, apps/graph, apps/vapi-webhook, apps/web.
REDIS_URL=redis://localhost:6379

# Test-only Redis (docker-compose.test.yml exposes on 6380).
# Used by: test harness (test/env.ts, test/globalSetup.ts).
REDIS_TEST_URL=redis://localhost:6380

# Test-only Postgres (docker-compose.test.yml exposes on 5433).
# Used by: test harness, infra/seed.
POSTGRES_TEST_URL=postgres://postgres:postgres@localhost:5433/postgres

# Primary Postgres / InsForge database URL. Replace <password> locally.
# Used by: apps/graph, apps/worker, apps/web, apps/vapi-webhook.
DATABASE_URL=postgresql://postgres:<password>@z5bpjses.us-west.database.insforge.app:5432/insforge?sslmode=verify-full

# -----------------------------------------------------------------------------
# Service ports and tokens
# -----------------------------------------------------------------------------

# HTTP port the service listens on. Per-app default.
# Used by: apps/graph, apps/vapi-webhook, apps/worker.
PORT=

# WunderGraph Cosmo router URL the SDK and apps target for GraphQL.
# Used by: apps/graph, apps/worker.
COSMO_ROUTER_URL=

# Service-to-service bearer token for the PreCall graph.
# Used by: apps/worker, apps/vapi-webhook.
PRECALL_SERVICE_TOKEN=

# Bearer token used by Vapi to call the PreCallBot meeting endpoint.
# Used by: apps/vapi-webhook, InsForge edge function, Vapi tool config.
PRECALL_INTERNAL_API_KEY=

# Optional SHA-256 hash of PRECALL_INTERNAL_API_KEY for hosted edge functions.
# Used by: InsForge edge function.
PRECALL_INTERNAL_API_KEY_SHA256=

# Default demo user for meeting lookups when call metadata does not include a user.
# Used by: apps/vapi-webhook, InsForge edge function.
PRECALL_DEFAULT_USER_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa

# -----------------------------------------------------------------------------
# Web (Next.js public vars are inlined at build time)
# -----------------------------------------------------------------------------

# Public GraphQL endpoint the browser SDK hits.
# Used by: apps/web.
NEXT_PUBLIC_GRAPH_ENDPOINT=

# Vapi public key used by the browser for voice sessions.
# Used by: apps/web.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Vapi assistant identifier bound to the PreCall voice flow.
# Used by: apps/web.
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Where the web app is served. Used for Set-Cookie + OAuth redirects.
# Used by: apps/web.
APP_URL=http://localhost:3000

# Session JWT signing secret. Min 32 bytes; rotate on compromise.
# Used by: apps/web.
SESSION_JWT_SECRET=dev-insecure-change-me-dev-insecure-change-me

# -----------------------------------------------------------------------------
# Vapi and PreCallBot webhook
# -----------------------------------------------------------------------------

# Vapi keys and resource IDs.
# Used by: apps/web, apps/vapi-webhook/configure-precallbot.
VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=
VAPI_PRECALLBOT_TOOL_ID=

# HMAC-SHA256 secret for verifying Vapi webhook signatures.
# Used by: apps/vapi-webhook.
VAPI_WEBHOOK_SECRET=

# Public URL for the self-hosted Vapi webhook, if not using PRECALL_TOOL_URL.
# Used by: apps/vapi-webhook/configure-precallbot.
VAPI_WEBHOOK_URL=https://api.precall.dev/vapi/webhook

# Public base URL for the self-hosted PreCallBot webhook.
# Used by: apps/vapi-webhook/configure-precallbot.
PRECALL_PUBLIC_BASE_URL=https://api.precall.dev

# Direct hosted tool URL for the deployed InsForge function.
# Used by: apps/vapi-webhook/configure-precallbot.
PRECALL_TOOL_URL=https://z5bpjses.functions.insforge.app/precall-next-meeting

# -----------------------------------------------------------------------------
# External research and LLM providers
# -----------------------------------------------------------------------------

# TinyFish API key for web extraction of public sources.
# Used by: apps/worker (packages/integrations tinyfish client).
TINYFISH_API_KEY=

# Gemini API key for LLM calls (Google AI Studio).
# Used by: apps/worker.
GEMINI_API_KEY=

# OpenAI API key. Reserved for future use.
OPENAI_API_KEY=

# Anthropic API key. Reserved for future use.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (primary login + Calendar R/W)
# -----------------------------------------------------------------------------

# Google OAuth client id.
# Used by: apps/web (primary login), apps/graph.
GOOGLE_CLIENT_ID=

# Google OAuth client secret.
# Used by: apps/web, apps/graph.
GOOGLE_CLIENT_SECRET=

# Google OAuth redirect URI (must exactly match the value registered in
# Google Cloud Console).
# Used by: apps/web.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# Notion OAuth (per-user page/database read grants)
# -----------------------------------------------------------------------------

# Notion OAuth client id.
# Used by: apps/web.
NOTION_OAUTH_CLIENT_ID=

# Notion OAuth client secret.
# Used by: apps/web.
NOTION_OAUTH_CLIENT_SECRET=

# Notion OAuth redirect URI (must exactly match the value registered at
# notion.com/my-integrations).
# Used by: apps/web.
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/notion/callback
