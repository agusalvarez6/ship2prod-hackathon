{
  "name": "s2p-hackathon",
  "version": "0.0.0",
  "private": true,
  "description": "PreCallBot. Voice-first meeting-prep agent (Ship to Prod 2026-04-24).",
  "type": "module",
  "engines": {
    "node": ">=20.10 <21",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "deploy:insforge:function": "node scripts/deploy-insforge-function.mjs",
    "test:docker:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:docker:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "infra:up": "docker compose up -d --wait postgres redis && bash scripts/setup-db.sh",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:psql": "docker compose exec postgres psql -U postgres",
    "infra:redis": "docker compose exec redis redis-cli",
    "graph:dev": "dotenv -e .env -- pnpm -F @ship2prod/graph exec tsx src/index.ts",
    "worker:dev": "dotenv -e .env -- pnpm -F @ship2prod/worker exec tsx src/index.ts",
    "web:dev": "dotenv -e .env -- pnpm -F @ship2prod/web dev",
    "stack:dev": "concurrently -n graph,worker,web -c blue,magenta,cyan 'pnpm graph:dev' 'pnpm worker:dev' 'pnpm web:dev'",
    "battleStation:start": "pnpm infra:up && pnpm stack:dev",
    "battleStation:stop": "docker compose down",
    "battleStation:reset": "docker compose down -v --remove-orphans && pnpm battleStation:start",
    "check": "pnpm lint && pnpm typecheck && pnpm test:run",
    "demo": "bash scripts/demo.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^20.14.0",
    "concurrently": "^9.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "execa": "^9.6.1",
    "globals": "^15.11.0",
    "ioredis": "^5.10.1",
    "msw": "^2.13.6",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^1.6.0"
  }
}
